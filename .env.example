# --- App-side environment variables ---
# All EXPO_PUBLIC_* vars are bundled into the client app and are NOT secret.
# Real secrets (WHOOP_CLIENT_SECRET, OPENAI_API_KEY) live ONLY in backend/.env.

# WHOOP OAuth public client ID. Required if you want to test WHOOP OAuth.
# The deployed pilot uses an existing client ID (already configured in eas.json
# for preview/production builds). Markers running locally do not need a value
# here — the app gracefully disables WHOOP if this is blank.
EXPO_PUBLIC_WHOOP_CLIENT_ID=

# Backend URL.
# - Leave blank for local Expo Go dev: the app auto-detects the LAN host.
# - For installed builds, this is set in eas.json (env block per profile)
#   so it is baked into the APK/IPA.
# - For markers running the web export or Expo Go against the deployed
#   backend, set: EXPO_PUBLIC_BACKEND_URL=https://life-balance-assistant.onrender.com
EXPO_PUBLIC_BACKEND_URL=

# Optional override for the LLM endpoint. If omitted, the app uses
# ${EXPO_PUBLIC_BACKEND_URL}/explain.
EXPO_PUBLIC_LLM_URL=
