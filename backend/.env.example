# --- Backend environment variables (server-side only) ---
# Markers do NOT need to populate this file unless they are deploying their
# own backend instance. The pilot uses the deployed Render backend at
# https://life-balance-assistant.onrender.com — see /health.

# WHOOP OAuth (required only if you are running your own backend with WHOOP)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# 32+ char random string. Encrypts the WHOOP token store at rest.
WHOOP_STORE_KEY=

# OpenAI (optional). If omitted, the app falls back to deterministic
# local templates and the demo still works fully.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Server config
PORT=3333

# Optional hardening
# SERVER_API_KEY=replace_with_shared_secret
# CORS_ORIGINS=http://localhost:8081,http://localhost:19006
